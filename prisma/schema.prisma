generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Delivery {
  id              String         @id @default(cuid())
  taskId          String
  projectName     String
  clientName      String
  deliverableType String
  department      String
  senderEmail     String
  primaryEmail    String
  ccEmails        String?
  slackChannel     String?
  slackChannelName String?
  emailSubject     String
  emailContent    String         @db.Text
  slackContent    String?        @db.Text
  wasEdited       Boolean        @default(false)
  sentBy          String
  sentAt          DateTime       @default(now())
  n8nExecutionId  String?
  n8nStatus       String?
  projectListId   String?
  clientFolderId  String?
  // When this delivery is a resend, points to the original Delivery it
  // corrects. Self-FK so we can chain (rare) and so analytics can exclude
  // resends from totals/leaderboard while still surfacing them in the
  // activity log.
  replacesDeliveryId String?
  replaces        Delivery?      @relation("DeliveryReplaces", fields: [replacesDeliveryId], references: [id])
  replacedBy      Delivery[]     @relation("DeliveryReplaces")
  // Snapshot of the user's per-delivery template + subject edits at send
  // time, so a resend can carry forward "what they meant to send" while
  // still picking up corrected form-field values via re-merge.
  editedSnippet   String?        @db.Text
  editedSubject   String?
  links           DeliveryLink[]
  createdAt       DateTime       @default(now())

  @@index([taskId])
  @@index([projectListId])
  @@index([clientFolderId])
  @@index([sentAt])
  @@index([replacesDeliveryId])
}

model DeliveryLink {
  id             String   @id @default(cuid())
  deliveryId     String
  delivery       Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  url            String
  label          String
  linkType       String
  variableName   String?
  projectListId  String
  clientFolderId String

  @@index([deliveryId])
  @@index([projectListId])
}

model Draft {
  id        String   @id @default(cuid())
  taskId    String   @unique
  formData  Json
  savedBy   String
  savedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
  scheduledFor      DateTime?
  scheduleStatus    String?
  scheduledPayload  Json?

  @@index([taskId])
  @@index([scheduledFor])
}

model TemplateVersion {
  id              String   @id @default(cuid())
  templateTaskId  String
  templateName    String
  snippet         String   @db.Text
  subjectLine     String
  deliverableType String
  department      String
  sender          String
  editedBy        String
  editedAt        DateTime @default(now())
  changeNote      String?

  @@index([templateTaskId])
  @@index([editedAt])
}

model AllowedSender {
  clickupUserId Int      @id
  addedBy       String
  addedAt       DateTime @default(now())

  @@index([addedAt])
}
